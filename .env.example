# Cloudflare Turnstile (contact form captcha)
#
# Get a widget key pair at: https://dash.cloudflare.com/?to=/:account/turnstile
#
# PUBLIC_ vars are exposed to the browser by Astro at build time. The secret is
# server-only and read by the Pages Function (functions/api/contact.ts) — set it
# in the Cloudflare Pages dashboard (Settings -> Environment variables), NOT here
# for production.
#
# The values below are Cloudflare's "always passes" test keys, handy for local
# dev. Replace with your real keys in production.

PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
