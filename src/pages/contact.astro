---
import Layout from '@/layouts/Layout.astro';
import { ContactForm } from '@/components/ContactForm';
---

<Layout title="Contact | Session Buddy">
  <main class="flex justify-center px-4 sm:px-6 lg:px-8 pb-24 pt-10">
    <section class="w-full max-w-2xl">
      <div class="px-6 sm:px-10 py-12 text-center">
        <h1
          class="text-4xl sm:text-5xl tracking-tight text-primaryTextColor"
        >
          Get in touch
        </h1>
        <p
          class="mx-auto mt-5 max-w-md text-lg leading-8 text-secondaryTextColor text-wrap-pretty"
        >
          Have a question, found a bug, or just want to say hi? Send us a
          message and we&apos;ll get back to you.
        </p>
      </div>
      <ContactForm client:load />
    </section>
  </main>
</Layout>
