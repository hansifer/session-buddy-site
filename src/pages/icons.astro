---
import Layout from '@/layouts/Layout.astro';

const iconModules = import.meta.glob('@/assets/icons/*.tsx', { eager: true });

const icons = Object.entries(iconModules)
  .map(([path, module]) => {
    const name = path.split('/').pop()?.replace('.tsx', '');

    if (!name) {
      return null;
    }

    const Component = (module as any)[name];

    if (!Component) {
      return null;
    }

    return { name, Component };
  })
  .filter(Boolean) as {
  name: string;
  Component: any;
}[];

// development-only page to view all app icons in one place

const S = 30;
---

<Layout
  title="Icon Showcase | Session Buddy"
  mode="docs"
>
  <main class="max-w-5xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-primaryTextColor mb-2">Icon Showcase</h1>
    <p class="text-secondaryTextColor mb-16">
      All icons in <code class="text-primaryColor">/src/assets/icons</code>
    </p>

    <section class="mb-20">
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6 text-orange-500"
      >
        {
          icons
            .map(({ name, Component }) => [
              name,
              <span class="w-6 h-6 inline-flex items-center">
                <Component
                  size={S}
                  className="w-7 h-7"
                />
              </span>,
            ])
            .sort(([nameA], [nameB]) => nameA.localeCompare(nameB))
            .map(([name, icon], i) => (
              <div class="flex flex-col items-center gap-3 p-5 rounded-2xl bg-blockBackgroundColor block-border">
                <div class="flex items-center justify-center h-10">{icon}</div>
                <span class="text-xs text-center text-secondaryTextColor font-mono leading-tight">
                  {`${i + 1}. ${name}`}
                </span>
              </div>
            ))
        }
      </div>
    </section>
  </main>
</Layout>
